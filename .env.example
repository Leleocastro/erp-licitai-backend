# ============================================
# ERP Licitai - Backend Environment Variables
# ============================================

# Application
NODE_ENV=development
APP_PORT=3000
APP_PREFIX=api
FRONTEND_URL=http://localhost:3001
HOST_APP_PORT=4000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=erp_licitai

# TypeORM
TYPEORM_SYNCHRONIZE=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# CORS
CORS_ORIGIN=http://localhost:3001

# Swagger
SWAGGER_ENABLED=true
SWAGGER_TITLE=ERP Licitai API
SWAGGER_DESCRIPTION=API do sistema ERP Licitai
SWAGGER_VERSION=1.0
SWAGGER_PATH=api/docs
